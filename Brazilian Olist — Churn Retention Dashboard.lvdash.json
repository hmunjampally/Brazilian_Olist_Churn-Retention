{
  "datasets": [
    {
      "name": "eb3cb81b",
      "displayName": "Platform Customer Metrics Overview Summary",
      "queryLines": [
        "-- Title: Platform KPIs\r\n",
        "-- Visualization: Counter (4 separate counter tiles)\r\n",
        "\r\n",
        "SELECT\r\n",
        "    COUNT(DISTINCT customer_unique_id)                        AS total_customers,\r\n",
        "    ROUND(SUM(monetary_value), 2)                            AS total_revenue,\r\n",
        "    ROUND(SUM(CASE WHEN segment IN ('At-Risk','Lost')\r\n",
        "          THEN monetary_value END), 2)                       AS revenue_at_risk,\r\n",
        "    SUM(CASE WHEN segment IN ('At-Risk','Lost')\r\n",
        "        THEN 1 ELSE 0 END)                                   AS customers_at_risk\r\n",
        "FROM brazilian.gold.churn_segments;\r\n",
        "\r\n",
        "\r\n",
        "\r\n"
      ]
    },
    {
      "name": "14bf687f",
      "displayName": "Customer Distribution Overview by Segment",
      "queryLines": [
        "-- Title: Customer Count by Segment\r\n",
        "-- Visualization: Bar Chart | X: segment | Y: customers\r\n",
        "\r\n",
        "SELECT\r\n",
        "    segment,\r\n",
        "    customers,\r\n",
        "    total_spend,\r\n",
        "    avg_ltv,\r\n",
        "    pct_of_total\r\n",
        "FROM brazilian.gold.segment_summary\r\n",
        "ORDER BY customers DESC;"
      ]
    },
    {
      "name": "0e950b81",
      "displayName": "Customer Satisfaction Analysis by Market Segment",
      "queryLines": [
        "-- Title: Satisfaction Score by Segment (Key Finding)\r\n",
        "-- Visualization: Bar Chart | X: segment | Y: avg_review_score\r\n",
        "-- Order: avg_review_score DESC\r\n",
        "\r\n",
        "SELECT\r\n",
        "    segment,\r\n",
        "    avg_review_score,\r\n",
        "    customers,\r\n",
        "    avg_recency_days\r\n",
        "FROM brazilian.gold.segment_summary\r\n",
        "ORDER BY avg_review_score DESC;"
      ]
    },
    {
      "name": "b75a2e40",
      "displayName": "High Priority Customers Lifetime Value Insights",
      "queryLines": [
        "-- Title: Top 20 At-Risk Customers by Lifetime Value\r\n",
        "-- Visualization: Table (keep as table, no chart needed)\r\n",
        "\r\n",
        "SELECT\r\n",
        "    customer_unique_id,\r\n",
        "    segment,\r\n",
        "    lifetime_value,\r\n",
        "    recency_days,\r\n",
        "    avg_review_score,\r\n",
        "    recommended_action,\r\n",
        "    suggested_channel,\r\n",
        "    recovery_potential_score\r\n",
        "FROM brazilian.gold.retention_priority\r\n",
        "LIMIT 20;"
      ]
    },
    {
      "name": "5721d4c6",
      "displayName": "Brazilian Customer Segments and Spending Overview",
      "queryLines": [
        "SELECT\r\n",
        "    c.customer_state,\r\n",
        "    COUNT(*)                          AS at_risk_customers,\r\n",
        "    ROUND(SUM(c.monetary_value), 2)   AS revenue_at_risk,\r\n",
        "    ROUND(AVG(c.monetary_value), 2)   AS avg_ltv\r\n",
        "FROM brazilian.gold.churn_segments c\r\n",
        "WHERE c.segment IN ('At-Risk', 'Lost')\r\n",
        "GROUP BY c.customer_state\r\n",
        "ORDER BY revenue_at_risk DESC\r\n",
        "LIMIT 10;"
      ]
    }
  ],
